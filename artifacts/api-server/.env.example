# ── Mysha Enterprise API Server — Environment ─────────────────────────────────
# Copy to .env and fill in real values. NEVER commit the real .env.

# Port the API listens on.
PORT=8080

# "development" or "production". In production the server enforces:
#   - a strong SESSION_SECRET (32+ chars)
#   - secure (HTTPS-only) session cookies
#   - SMTP must be configured (verification codes are never returned in responses)
NODE_ENV=development

# PostgreSQL connection string.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Secret used to sign session cookies. Generate with: openssl rand -base64 48
# REQUIRED in production (must be 32+ characters).
SESSION_SECRET=change-me-to-a-long-random-string

# Comma-separated list of browser origins allowed to make credentialed
# cross-origin API calls in production. Example:
#   ALLOWED_ORIGINS=https://mysha-enterprise.com,https://www.mysha-enterprise.com
# In development, any localhost origin is allowed automatically.
ALLOWED_ORIGINS=

# ── Email (Resend HTTP API) ──────────────────────────────────────────────────
# Used to send signup verification and password-reset codes. Resend sends over
# HTTPS, so it works on serverless hosts like Vercel (which block raw SMTP).
# REQUIRED in production: if RESEND_API_KEY is unset in production the server
# refuses to send (and never leaks the code to the client). Get a key at
# https://resend.com → API Keys.
RESEND_API_KEY=re_your_api_key
# From address. Defaults to Resend's shared test sender if unset. For production
# verify your own domain in Resend and use e.g. "Mysha Enterprise <noreply@yourdomain.com>".
EMAIL_FROM=Mysha Enterprise <onboarding@resend.dev>

# ── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Shared, serverless-safe rate limiting. Without these, rate limiting falls back
# to per-instance in-memory counting, which does NOT protect you on Vercel.
# Create a free database at https://upstash.com → copy the REST URL + token.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── Notes for Vercel ─────────────────────────────────────────────────────────
# - DATABASE_URL must be a CLOUD Postgres POOLED connection string (e.g. Neon's
#   "-pooler" host). A local/non-pooled URL will not work on Vercel.
# - Set NODE_ENV=production in Vercel (it sets this automatically on prod builds).
# - Vercel sets the VERCEL=1 variable automatically; the DB layer uses it to
#   shrink the connection pool.

