# ── Mysha Enterprise Frontend — Local Environment ─────────────────────────────
#
# Rename this file to .env before running pnpm run dev.
# Vite reads it automatically. Never commit the real .env to git.
#
# The Vite dev proxy (vite.config.ts) forwards all /api/* requests to this URL.
VITE_API_BASE_URL=http://localhost:8080
