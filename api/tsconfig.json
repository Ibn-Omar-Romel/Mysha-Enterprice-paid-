{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "strict": false,
    "noEmit": false,
    "noEmitOnError": false,
    "types": ["node"]
  },
  "include": ["index.ts"]
}
